# Canonical live-LLM paper rehearsal profile.
# Source this after the base .env and replace placeholder artifact paths with
# deployment-local absolute paths or object-store mounted paths.
QP__BROKER__PAPER_TRADING=true

QP__ALPHA__ENSEMBLE_MODE=live
QP__ALPHA__SOURCE_WEIGHTS='{"classical":0.99,"text":0.01,"xgboost":0.0,"event":0.0,"intraday":0.0}'
QP__ALPHA__MAX_NON_CLASSICAL_WEIGHT=0.01
QP__ALPHA__LIVE_RAMP_INITIAL=0.01
QP__ALPHA__FAIL_CLOSED_ON_PROMOTED_SOURCE_ERROR=true
QP__ALPHA__REQUIRE_PROMOTION_GATE=true

QP__LLM__SHADOW_MODE_ENABLED=true
QP__LLM__LIVE_MODE_ENABLED=true
QP__LLM__LIVE_REHEARSAL_ENABLED=true
QP__LLM__REPLAY_ONLY_LIVE=true
QP__LLM__TEXT_MODEL_MANIFEST=<absolute-or-object-store-path>
QP__LLM__TEXT_FEATURE_CARD_DIR=<absolute-path-to-feature-card-dir>
QP__LLM__LIVE_EVIDENCE_STALE_AFTER_DAYS=3
QP__LLM__LIVE_STARTUP_ASSERTION_STALE_AFTER_HOURS=24
QP__LLM__MAX_REQUEST_LATENCY_SECONDS=30
QP__LLM__MAX_DAILY_CALLS=1
QP__LLM__MAX_DAILY_ESTIMATED_COST_USD=1
