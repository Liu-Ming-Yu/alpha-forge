# Example environment file — copy to .env in the project root and fill in.
# Never commit .env to source control.
#
# Variable naming: QP__<SECTION>__<FIELD>
# Pydantic Settings resolves QP__BROKER__PORT → settings.broker.port

# ---- IB TWS / Gateway ----
QP__BROKER__HOST=host.docker.internal     # WSL -> Windows TWS; use 127.0.0.1 only when TWS runs in the same OS namespace
QP__BROKER__PORT=7497                     # TWS paper=7497, TWS live=7496, GW paper=4002, GW live=4001
QP__BROKER__CLIENT_ID=985                 # choose a fresh unused numeric socket ID for each live smoke run; NOT the account string
QP__BROKER__ACCOUNT_ID=                   # IBKR account string, e.g. DU4502835 (paper) or U1234567 (live)
QP__BROKER__PAPER_TRADING=true            # set to false for live trading
QP__BROKER__REQUEST_TIMEOUT_SECONDS=10.0
QP__BROKER__RECONNECT_BASE_DELAY=2.0
QP__BROKER__RECONNECT_MAX_DELAY=60.0
QP__BROKER__PRIMARY_BROKER_PATH=tws          # tws | client_portal | dual
QP__BROKER__HEARTBEAT_INTERVAL_SECONDS=5.0
QP__BROKER__MAX_CONSECUTIVE_HEALTH_FAILURES=3
QP__BROKER__RECONCILE_ON_RECONNECT=true
QP__BROKER__STALE_DAY_ORDER_CLEANUP_MINUTES=30
# Optional long-lived-order cleanup. 0 disables GTC/GTD cleanup; set only after
# the paper soak proves the expected stale-order policy.
QP__BROKER__STALE_GTC_CLEANUP_MINUTES=0
QP__LIVE_IBKR__CONTRACTS_FILE=infra/config/paper_contracts.json  # paper smoke/probe contract map with IBKR-resolved con_id values

# ---- Risk limits ----
QP__RISK__MAX_SINGLE_NAME_WEIGHT=0.05
QP__RISK__MAX_SECTOR_WEIGHT=0.20
QP__RISK__MAX_GROSS_EXPOSURE=0.95
QP__RISK__MAX_DAILY_TURNOVER=0.20
QP__RISK__MIN_CASH_BUFFER=0.05
QP__RISK__MAX_DRAWDOWN_HALT=-0.15
# QP__RISK__VOL_TARGET_ANNUALISED=0.12    # optional — uncomment to enable
QP__RISK__AUTO_CORRECT_THRESHOLD=1        # reconciliation mismatch auto-correct (shares)
# Fail session start when any tradable instrument is missing a sector label.
# Previously unmapped names fell into an "UNKNOWN" bucket that silently
# concentrated sector risk.  Flip to false for exploratory backtests only.
QP__RISK__REQUIRE_SECTOR_MAPPING=true
QP__RISK__HALT_ON_STALE_FEATURES=false
# Optional JSON map of correlated ETFs capped as a group:
# {"us_broad":["SPY","QQQ","IWM"],"rates":["TLT"]}
QP__RISK__ETF_CORRELATION_GROUPS={}
QP__RISK__ETF_GROUP_CAP_MULTIPLIER=1.5

# ---- Order throttle (token bucket) ----
QP__THROTTLE__CAPACITY=10
QP__THROTTLE__REFILL_RATE=2.0

# ---- Liquidity / ADV participation ----
QP__LIQUIDITY__ADV_PARTICIPATION_PCT=0.05    # max 5% of 20-day ADV
QP__LIQUIDITY__MIN_ADV_USD=1000000           # min $1M daily volume
# Strict ADV: reject orders for instruments that do not yet have a
# LiquidityProfile.  Previously silently accepted with a conservative
# fallback which could size orders above the true ADV in thin names.
# Flip to true for paper/CI when deliberately seeding partial universes.
QP__LIQUIDITY__ALLOW_MISSING_PROFILE=false

# ---- Execution ----
# Reject order submissions outside US equities regular trading hours
# (09:30-16:00 America/New_York, Mon-Fri, excluding NYSE holidays + half-days).
# Flip to false for backtest/CI harnesses that replay historical timestamps.
QP__EXECUTION__TRADING_HOURS_ENFORCED=true
# Execution-tactic controls surfaced by the production preflight and session
# wiring.  The current live path uses LIMIT by default; close-auction routing
# switches generated intents to MOC for the closing policy.
QP__EXECUTION__PASSIVE_LIMIT_ENABLED=false
QP__EXECUTION__REPRICE_INTERVAL_SECONDS=300
QP__EXECUTION__CLOSE_AUCTION_ENABLED=false
QP__EXECUTION__ORDER_TIMEOUT_SECONDS=1800

# ---- Cash ledger ----
QP__CASH__RESERVATION_BUFFER_PCT=0.01     # 1% buffer on top of notional
QP__CASH__RESERVATION_TTL_MINUTES=30      # minutes before unsubmitted reservations expire
QP__CASH__DRIFT_TOLERANCE_USD=1.00        # max tolerated broker-vs-ledger settled-cash drift

# ---- Data ingest (secondary/tertiary EOD vendors) ----
# IB remains primary for `ingest` (default --data-source ib). Configure one
# vendor with BAR_FETCH_FALLBACK, or set BAR_FETCH_FALLBACK_CHAIN (JSON array)
# for a multi-vendor ordered chain. BAR_FETCH_FALLBACK_CHAIN supersedes
# BAR_FETCH_FALLBACK when non-empty.
# For large historical backfills (300+ names x multi-year), run
# `ingest --data-source vendor`: it skips IB entirely and fetches directly
# from the configured vendor(s), avoiding IB per-instrument pacing limits.
# See docs/runbooks/ingest-and-backfill.md for full chain semantics.
QP__DATA_INGEST__BAR_FETCH_FALLBACK=none            # none | tiingo | polygon
# QP__DATA_INGEST__BAR_FETCH_FALLBACK_CHAIN=["tiingo","polygon"]  # three-vendor chain
# QP__DATA_INGEST__TIINGO_API_TOKEN=                # required when tiingo is in chain
# QP__DATA_INGEST__POLYGON_API_KEY=                 # required when polygon is in chain
# QP__DATA_INGEST__POLYGON_BASE_URL=https://api.polygon.io
# QP__DATA_INGEST__POLYGON_MAX_CONCURRENT=10
# QP__DATA_INGEST__POLYGON_TIMEOUT_SECONDS=30.0
# Required by SEC EDGAR for governed text/catalyst ingestion.
# QP__DATA_INGEST__SEC_USER_AGENT="QuantPlatform research contact@example.com"
QP__DATA_INGEST__MAX_BAR_AGE_MINUTES=60

# ---- Storage ----
QP__STORAGE__POSTGRES_DSN=postgresql+psycopg://user:password@localhost:5432/quant_platform
QP__STORAGE__REDIS_URL=redis://localhost:6379/0
QP__STORAGE__OBJECT_STORE_ROOT=./data/parquet
QP__STORAGE__EVENT_BUS_BACKEND=redis_streams      # in_memory | redis_streams
QP__STORAGE__REDIS_STREAM_PREFIX=qp:events
QP__STORAGE__REDIS_STREAM_MAXLEN=10000
QP__STORAGE__REDIS_STREAM_RETENTION_MS=604800000  # 7 days; set 0 to disable XTRIM sweeper
QP__STORAGE__REDIS_STREAM_SWEEPER_INTERVAL_SECONDS=900
QP__STORAGE__REDIS_STREAM_DEAD_LETTER_AFTER_RETRIES=5
QP__STORAGE__REDIS_STREAM_PUBLISH_DEDUPE_ENABLED=true
QP__STORAGE__REDIS_STREAM_DEDUPE_TTL_SECONDS=604800
QP__STORAGE__FEATURE_RETENTION_DAYS=0             # 0 = retention CLI requires explicit --keep-days
QP__STORAGE__POSTGRES_POOL_MIN=2
QP__STORAGE__POSTGRES_POOL_MAX=10

# ---- Production readiness gates ----
QP__PRODUCTION__DATA_HEALTH_MIN_COVERAGE_PCT=1.0
QP__PRODUCTION__DATA_HEALTH_MIN_LIQUIDITY_COVERAGE_PCT=1.0
QP__PRODUCTION__DATA_HEALTH_STALE_AFTER_DAYS=3
QP__PRODUCTION__TEXT_GATE_MIN_OBSERVATIONS=20
QP__PRODUCTION__TEXT_GATE_MIN_IC=0.05
QP__PRODUCTION__TEXT_GATE_MAX_NEGATIVE_STREAK=3
QP__PRODUCTION__SIGNAL_GATE_MAX_DRAWDOWN=-0.10
QP__PRODUCTION__SIGNAL_GATE_MAX_TURNOVER=1.0
QP__PRODUCTION__HEARTBEAT_STALE_AFTER_MINUTES=10

# ---- Logging ----
QP__LOGGING__LOG_LEVEL=INFO
QP__LOGGING__LOG_FORMAT=json              # "json" or "console"

# ---- Operator API (read-only views: cash, blotter, audit, metrics) ----
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
QP__API__OPERATOR_API_KEY=
# Dual opt-in escape hatch.  When QP__API__OPERATOR_API_KEY is blank, the API
# refuses to start unless both flags are explicitly true.  DO NOT enable in
# production; a SECURITY_WARNING is logged whenever they are.
QP__API__ALLOW_UNAUTHENTICATED=false
QP__API__ACKNOWLEDGE_UNAUTHENTICATED_RISK=false
# Simple per-key / per-host token bucket (requests per minute).  Set to 0 to
# disable rate limiting.
QP__API__RATE_LIMIT_PER_MINUTE=120
# Comma-separated list of origins allowed for CORS.  Empty = deny all cross
# origin requests (recommended).  Example: https://ops.mycompany.com
QP__API__CORS_ALLOW_ORIGINS=
# Expose the Prometheus /metrics endpoint. It is protected by the operator API
# key unless the full unauthenticated dev/smoke-test escape hatch is active.
QP__API__EXPOSE_METRICS=false

# ---- LLM text features (optional) ----
# Default provider remains Anthropic and reads ANTHROPIC_API_KEY directly.
# To use DeepSeek, set DEEPSEEK_API_KEY in the process environment and switch:
# QP__LLM__PROVIDER=deepseek
# QP__LLM__MODEL=deepseek-v4-flash
# QP__LLM__DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
QP__LLM__PROVIDER=anthropic
QP__LLM__MODEL=claude-sonnet-4-6
QP__LLM__TEXT_PROMPT_VERSION=v1
# MAX_TOKENS: must fit the configured prompt's JSON output. 3000 is the
# tested default for the v4 catalyst prompt (15 features); 1000 truncates.
QP__LLM__MAX_TOKENS=3000
# TIMEOUT_SECONDS: per-HTTP-call timeout. 120 because a 3000-token response
# from DeepSeek routinely takes 60-90s; 30s causes retry storms.
QP__LLM__TIMEOUT_SECONDS=120.0
# MAX_REQUEST_LATENCY_SECONDS: per-request latency cap. Platform invariant:
# must be <= TIMEOUT_SECONDS. Defaults equal to TIMEOUT_SECONDS (120).
# QP__LLM__MAX_REQUEST_LATENCY_SECONDS=120.0
QP__LLM__SHADOW_MODE_ENABLED=false
QP__LLM__LIVE_MODE_ENABLED=false
QP__LLM__LIVE_REHEARSAL_ENABLED=false

# ---- Classical signal model ----
# Path to a research-campaign manifest (campaign_manifest.json). When set, the
# live classical model uses the walk-forward IC-fitted 'selected_weights' from
# that campaign instead of the hand-picked QP__FACTORS__*_WEIGHT priors, and
# pins the model's expected feature_set_version. Leave empty to use defaults.
# QP__FACTORS__FITTED_WEIGHTS_MANIFEST=data/parquet/research/walk_forward/<run-id>/campaign_manifest.json

# ---- Alpha paper ensemble (enable only after production-candidate passes) ----
# QP__ALPHA__ENSEMBLE_MODE=paper
# QP__ALPHA__PROMOTED_FEATURE_SET_VERSION=paper-alpha-composite-v1
# QP__ALPHA__SOURCE_WEIGHTS={"classical":0.70,"xgboost":0.15,"text":0.05,"event":0.05,"intraday":0.05}
# QP__ALPHA__PAPER_MAX_NON_CLASSICAL_WEIGHT=0.30
# QP__ALPHA__MAX_NON_CLASSICAL_WEIGHT=0.01
# QP__BOOSTING__ARTIFACT_MANIFEST=data/parquet/research/walk_forward/models/xgboost/paper-alpha-xgboost-v1-text-core__search_0/manifest.json
# QP__BOOSTING__DEVICE=auto
# QP__LLM__SHADOW_MODE_ENABLED=true
# QP__LLM__LIVE_MODE_ENABLED=false

# ---- Regime detector ----
QP__REGIME__ENABLED=true
QP__REGIME__MARKET_PROXY_INSTRUMENT_ID=    # UUID of SPY/QQQ/VTI (leave empty to skip in-cycle update)
QP__REGIME__TREND_WINDOW=200
QP__REGIME__VOL_WINDOW=21
QP__REGIME__BREADTH_WINDOW=50
QP__REGIME__LOOKBACK_DAYS=380

# ---- Broker historical data (live market-data path) ----
QP__BROKER__HISTORICAL_BAR_FETCH_ENABLED=false
QP__BROKER__HISTORICAL_BAR_PACING_WINDOW_SECONDS=600
QP__BROKER__HISTORICAL_BAR_PACING_MAX_REQUESTS=60
